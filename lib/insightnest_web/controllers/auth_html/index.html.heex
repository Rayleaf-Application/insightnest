<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sign in — InsightNest</title>
  <link rel="stylesheet" href={~p"/assets/app.css"} />
</head>
<body class="h-full bg-stone-950 flex items-center justify-center font-sans">

  <div class="w-full max-w-sm px-6">

    <!-- Logo / wordmark -->
    <div class="text-center mb-10">
      <h1 class="text-2xl font-semibold tracking-tight text-stone-100">
        InsightNest
      </h1>
      <p class="mt-2 text-sm text-stone-400">
        Sign in to start contributing
      </p>
    </div>

    <!-- Error banner (hidden by default) -->
    <div
      id="auth-error"
      class="hidden mb-6 rounded-lg border border-red-800 bg-red-950 px-4 py-3 text-sm text-red-300"
      role="alert"
    ></div>

    <!-- Connect wallet button -->
    <button
      id="btn-connect"
      class="w-full rounded-xl bg-violet-600 px-4 py-3 text-sm font-medium text-white
             hover:bg-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-400
             disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
    >
      Connect Wallet
    </button>

    <!-- Wallet state (hidden until connected) -->
    <div id="wallet-state" class="hidden mt-6 space-y-4">
      <div class="rounded-xl border border-stone-700 bg-stone-900 px-4 py-3">
        <p class="text-xs text-stone-500 uppercase tracking-widest mb-1">Connected</p>
        <p
          id="wallet-address"
          class="font-mono text-sm text-stone-200 break-all"
        ></p>
      </div>

      <button
        id="btn-sign"
        class="w-full rounded-xl bg-violet-600 px-4 py-3 text-sm font-medium text-white
               hover:bg-violet-500 focus:outline-none focus:ring-2 focus:ring-violet-400
               disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
      >
        Sign in with Ethereum
      </button>
    </div>

    <!-- Loading state -->
    <div id="loading" class="hidden mt-4 text-center text-sm text-stone-400">
      <span id="loading-text">Waiting for wallet…</span>
    </div>

    <!-- Divider (placeholder for email auth in Sprint 6) -->
    <div class="mt-8 flex items-center gap-4">
      <div class="flex-1 border-t border-stone-800"></div>
      <span class="text-xs text-stone-600">or</span>
      <div class="flex-1 border-t border-stone-800"></div>
    </div>

    <p class="mt-4 text-center text-sm text-stone-500">
      Email sign-in coming soon
    </p>

  </div>

  <script>
    // ── State ──────────────────────────────────────────────────────────────────
    let connectedAddress = null;

    const $ = (id) => document.getElementById(id);

    // ── UI helpers ─────────────────────────────────────────────────────────────
    function showError(msg) {
      const el = $("auth-error");
      el.textContent = msg;
      el.classList.remove("hidden");
    }

    function clearError() {
      const el = $("auth-error");
      el.textContent = "";
      el.classList.add("hidden");
    }

    function setLoading(text) {
      $("loading").classList.remove("hidden");
      $("loading-text").textContent = text;
    }

    function clearLoading() {
      $("loading").classList.add("hidden");
    }

    function setButtonState(id, disabled, text) {
      const btn = $(id);
      btn.disabled = disabled;
      if (text) btn.textContent = text;
    }

    // ── SIWE message builder ───────────────────────────────────────────────────
    // Constructs a spec-compliant EIP-4361 message.
    // Must match exactly what ex_siwe expects to parse.
    function buildSiweMessage(address, nonce) {
      const domain   = window.location.host;
      const origin   = window.location.origin;
      const issuedAt = new Date().toISOString();

      return [
        `${domain} wants you to sign in with your Ethereum account:`,
        address,
        ``,
        `Sign in to InsightNest`,
        ``,
        `URI: ${origin}`,
        `Version: 1`,
        `Chain ID: 1`,
        `Nonce: ${nonce}`,
        `Issued At: ${issuedAt}`,
      ].join("\n");
    }

    // ── Step 1: Connect MetaMask ───────────────────────────────────────────────
    $("btn-connect").addEventListener("click", async () => {
      clearError();

      if (!window.ethereum) {
        showError("No Ethereum wallet detected. Install MetaMask and try again.");
        return;
      }

      try {
        setLoading("Connecting wallet…");
        setButtonState("btn-connect", true);

        const accounts = await window.ethereum.request({
          method: "eth_requestAccounts"
        });

        if (!accounts || accounts.length === 0) {
          throw new Error("No accounts returned from wallet.");
        }

        connectedAddress = accounts[0];

        // Show wallet state panel
        $("wallet-address").textContent = connectedAddress;
        $("wallet-state").classList.remove("hidden");
        $("btn-connect").classList.add("hidden");
        clearLoading();

      } catch (err) {
        clearLoading();
        setButtonState("btn-connect", false);
        showError(err.message || "Failed to connect wallet.");
      }
    });

    // ── Step 2: Sign SIWE message and verify ──────────────────────────────────
    $("btn-sign").addEventListener("click", async () => {
      if (!connectedAddress) {
        showError("No wallet connected.");
        return;
      }

      clearError();
      setButtonState("btn-sign", true, "Requesting nonce…");

      try {
        // 2a. Get nonce from server
        const nonceRes = await fetch(
          `/auth/nonce?address=${encodeURIComponent(connectedAddress)}`,
          { headers: { "Accept": "application/json" } }
        );

        if (!nonceRes.ok) {
          throw new Error("Failed to retrieve nonce from server.");
        }

        const { nonce } = await nonceRes.json();

        // 2b. Build SIWE message
        const message = buildSiweMessage(connectedAddress, nonce);

        // 2c. Request signature from wallet
        setButtonState("btn-sign", true, "Check your wallet…");

        const signature = await window.ethereum.request({
          method: "personal_sign",
          params: [message, connectedAddress]
        });

        // 2d. Submit to server for verification
        setButtonState("btn-sign", true, "Verifying…");

        const verifyRes = await fetch("/auth/verify", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({ message, signature })
        });

        const data = await verifyRes.json();

        if (!verifyRes.ok) {
          throw new Error(data.error || "Verification failed.");
        }

        // 2e. Store token in localStorage for any future API calls
        // Session cookie is set by the server — LiveView reads from session.
        localStorage.setItem("insightnest_token", data.token);

        // 2f. Redirect to home
        setButtonState("btn-sign", true, "Signing in…");
        window.location.href = "/";

      } catch (err) {
        clearLoading();
        setButtonState("btn-sign", false, "Sign in with Ethereum");

        // User rejected the signature request
        if (err.code === 4001) {
          showError("Signature rejected. Sign in was cancelled.");
        } else {
          showError(err.message || "Something went wrong. Please try again.");
        }
      }
    });
  </script>

</body>
</html>